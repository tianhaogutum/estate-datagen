@prefix :    <https://example.org/wartung#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# EconomicUnit
:eu-1 a :EconomicUnit ;
    :name "Wohnpark Nord" ;
    :economicUnitType "Wirtschaftseinheit" .

# Building
:bld-1 a :Building ;
    :economicUnit :eu-1 ;
    :name "Haus A" ;
    :address "Musterstraße 1, 10115 Berlin" .

# ServiceProvider
:sp-1 a :ServiceProvider ;
    :name "HVAC Service GmbH" .

# Device
:dev-1 a :Device ;
    :building :bld-1 ;
    :deviceType "WAERMEPUMPE" .

# MaintenanceContract — ANNUAL from 2024-01-15, runs until 2026-01-14
:ct-1 a :MaintenanceContract ;
    :contractBuilding :bld-1 ;
    :deviceType "WAERMEPUMPE" ;
    :serviceProvider :sp-1 ;
    :contractDate  "2024-01-10"^^xsd:date ;
    :contractStart "2024-01-15"^^xsd:date ;
    :contractEnd   "2026-01-14"^^xsd:date ;
    :terminationPeriodMonths 3 ;
    :terminationDeadlineRule "END_OF_YEAR" ;
    :maintenanceFrequency "ANNUAL" ;
    :costPerMaintenance "450.00"^^xsd:decimal .

# Two protocols at ~1-year intervals, within ±14 days of anniversary
:pr-1 a :MaintenanceProtocol ;
    :contract :ct-1 ;
    :device :dev-1 ;
    :deviceType "WAERMEPUMPE" ;
    :maintenanceDate "2024-01-20"^^xsd:date ;
    :maintenanceType "WARTUNG" ;
    :performedBy :sp-1 ;
    :resultDeficiency false ;
    :status "COMPLETED" .

:pr-2 a :MaintenanceProtocol ;
    :contract :ct-1 ;
    :device :dev-1 ;
    :deviceType "WAERMEPUMPE" ;
    :maintenanceDate "2025-01-22"^^xsd:date ;
    :maintenanceType "WARTUNG" ;
    :performedBy :sp-1 ;
    :resultDeficiency true ;
    :deficiencyType "MINOR" ;
    :status "COMPLETED" .
